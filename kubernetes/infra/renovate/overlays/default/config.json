{
  "platform": "github",
  "repositories": [
    "leehosanganson/homelab"
  ],
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "onboarding": false,
  "requireConfig": "optional",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "pinDigests": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 20,
  
  "internalChecksFilter": "flexible",
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "description": "Apply minimum release age only to github-releases (Docker/Helm lack reliable timestamps)",
      "matchDatasources": ["github-releases"],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Automatically merge non-breaking patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group all FluxCD system component updates together to avoid PR spam",
      "matchPackageNames": ["ghcr.io/fluxcd/**", "fluxcd/flux2"],
      "groupName": "flux-system"
    },
    {
      "description": "Disable digest pinning for the Flux GitHub release to prevent errors in gotk-components",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["fluxcd/flux2"],
      "pinDigests": false
    },
    {
      "description": "Ignore Paths",
      "matchPaths" : [
        "kubernetes/infra/cloudnativepg/**",
        "kubernetes/infra/synology-csi/**"
      ],
      "enabled": false
    },
    {
      "description": "Digest Updates Schedule",
      "matchUpdateTypes": ["digest"],
      "schedule": ["on Sunday"],
      "enabled": true
    }
  ],
  "flux": {
    "managerFilePatterns": [
      "/^fluxcd/clusters/production/.+\\.ya?ml$/",
      "/kubernetes/.+/base/release\\.ya?ml$/",
      "/kubernetes/infra/helm/.*\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^kubernetes/.+\\.ya?ml$/",
      "!/kubernetes/.+/base/release\\.ya?ml$",
      "!/kubernetes/infra/helm/.*\\.ya?ml$"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/^kubernetes/.+/values\\.ya?ml$/"
    ]
  }
}
