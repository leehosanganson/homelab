        REDIS_I["Redis\nImmich"]:::db
        REDIS_P["Redis\nPaperless"]:::db
    end

    subgraph Productivity["Productivity & Dev Tools"]
        AB["Actual Budget"]:::svc
        CHROME["Chrome"]:::svc
        ITTOOL["IT-Tools"]:::svc
        TERMIX["Termix"]:::svc
        WHOAMI["Whoami"]:::svc
        PORTFOLIO["Portfolio"]:::svc
    end

