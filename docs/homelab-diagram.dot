digraph Homelab_Pro {
    // Global Settings for a "System Blueprint" Aesthetic
    graph [
        rankdir=TB, 
        compound=true, 
        splines=ortho, 
        pad=0.5,            
        nodesep=0.4,        
        ranksep=1.2,        
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=16,        
        bgcolor="#09090B"
    ];

    // Global Node Defaults 
    node [
        shape=box, 
        style="rounded,filled", 
        fillcolor="#18181B",
        color="#3F3F46",
        fontcolor="#FAFAFA", 
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=11,        
        margin="0.2,0.15",
        penwidth=1.5
    ];
    
    // Global Edge Defaults
    edge [
        color="#52525B", 
        fontcolor="#A1A1AA", 
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=10,        
        penwidth=1.2, 
        arrowsize=0.8
    ];


    subgraph cluster_gitops {
        label="GITOPS & IaC";
        style="rounded,filled"; fillcolor="#111111"; color="#7C3AED"; fontcolor="#A78BFA"; 
        fontsize=13; margin=15; 
        node [color="#7C3AED"]; 

        github [label="GitHub Repo\nFlux + Tofu Sources"];
        nixos  [label="NixOS\nOS Config"];
        tofu   [label="OpenTofu\nVM Provisioning"];
        flux   [label="FluxCD\nK8s Reconciliation"];
    }

    subgraph cluster_external {
        label="EXTERNAL RESOURCES";
        style="rounded,filled"; fillcolor="#111111"; color="#0EA5E9"; fontcolor="#7DD3FC"; 
        fontsize=13; margin=15;
        node [color="#0EA5E9"];
        
        azure_kv [label="Azure Key Vault\nSecrets"];
        syn_nas  [label="Synology NAS\nNFS Volumes"];
    }

    subgraph cluster_network {
        label="NETWORK ENTRY";
        style="rounded,filled"; fillcolor="#111111"; color="#3B82F6"; fontcolor="#93C5FD"; 
        fontsize=13; margin=15;
        node [color="#3B82F6"];

        users    [label="Users\nPublic/LAN/VPN"];
        ingress  [label="Traefik Ingress\nController", fillcolor="#1E3A8A"];
        
        {rank=same; users; ingress;}
        users -> ingress;
    }

    subgraph cluster_infra {
        label="INFRASTRUCTURE & PLATFORM";
        style="rounded,filled"; fillcolor="#111111"; color="#10B981"; fontcolor="#6EE7B7"; 
        fontsize=13; margin=15;
        node [color="#10B981"];

        proxmox [label="Proxmox VE Cluster\n3 Nodes (2 Mini, 1 GPU)"];
        k3s     [label="K3s Cluster\nControl + GPU Nodes"];
        platform [label="Core Services\nCert-Manager, Harbor"];
        storage  [label="Data & Storage\nCloudNativePG, CSI"];
        obs      [label="Observability\nProm, Grafana, Loki"];

        {rank=same; proxmox; k3s; storage;}
        proxmox -> k3s;
        {rank=same; platform; obs;}
    }

    subgraph cluster_workloads {
        label="PRODUCTION WORKLOADS";
        style="rounded,filled"; fillcolor="#111111"; color="#EF4444"; fontcolor="#FCA5A1"; 
        fontsize=13; margin=15;
        node [color="#EF4444"];

        ai_apps   [label="AI: LiteLLM, Open WebUI", color="#EF4444"];
        media     [label="Media: Jellyfin, *arr", color="#EF4444"];
        docs      [label="Docs: Paperless, Karakeep", color="#EF4444"];
        utility   [label="Util: Homepage, Budget", color="#EF4444"];
        dev       [label="Dev: n8n, Coder", color="#EF4444"];
        home      [label="Home: Assistant, MC", color="#EF4444"];

        {rank=same; ai_apps; media; docs;}
        {rank=same; utility; dev; home;}
    }

    // ==========================================
    // SYSTEM WIRING (Horizontal "Blueprints")
    // ==========================================
    
    // Provisioning
    tofu -> proxmox [xlabel=" Provisions ", style=dashed, color="#A1A1AA"];
    flux -> k3s     [xlabel=" Reconciles ", style=dashed, color="#A1A1AA"];
    
    // Data & Secrets
    azure_kv -> platform [xlabel=" Secrets ", style=dashed, color="#0EA5E9"];
    syn_nas -> storage   [xlabel=" Mounts ", style=dashed, color="#0EA5E9"];

    // Traffic Flow
    ingress -> ai_apps [lhead=cluster_workloads, color="#F59E0B", penwidth=2, xlabel=" Routes Traffic "];

    // ==========================================
    // HIDDEN ANCHORS (The secret to a 4:3 fit)
    // ==========================================
    // edge [style=invis];
    // Centering
    tofu -> proxmox -> k3s -> docs;

    // Left
    github -> azure_kv -> ingress -> ai_apps;

}
