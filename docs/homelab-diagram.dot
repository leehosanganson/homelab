digraph Homelab {
    // Global Graph Settings
    graph [
        rankdir=LR, 
        compound=true, 
        splines=polyline, 
        pad=0.5,            
        nodesep=0.5,        // Slightly increased to let nodes breathe
        ranksep=1.5,        // Pulls the left and right columns closer together
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=16,        
        bgcolor="#1E1E1E"
    ];

    // Global Node Defaults (Made slightly "chunkier" to fill space)
    node [
        shape=box, 
        style="rounded,filled", 
        fillcolor="#333333", 
        color="#555555", 
        fontcolor="#FFFFFF", 
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=12,        
        margin="0.3,0.25"   // Increased margin to make buttons look fuller
    ];
    
    // Global Edge Defaults
    edge [
        color="#888888", 
        fontcolor="#AAAAAA", 
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=11,        
        penwidth=1.5, 
        arrowsize=0.8
    ];

    // ==========================================
    // CLUSTER 1: GitOps & IaC
    // ==========================================
    subgraph cluster_gitops {
        label="GitOps & IaC (Two-Layer)";
        style="rounded,filled"; fillcolor="#2A2A2A"; color="#444444"; fontcolor="#E0E0E0"; 
        fontsize=14; 
        margin=20; // Increased to fill out the box
        node [fillcolor="#44337A", color="#553C9A"]; 

        github [label="GitHub Repo\nBase/Overlays"];
        nixos [label="NixOS + sops-nix\nOS Config & Secrets"];
        opentofu [label="OpenTofu\nVM Provisioning"];
        fluxcd [label="FluxCD\nContinuous Recon."];

        {rank=same; github; nixos;}
        {rank=same; opentofu; fluxcd;}
        github -> opentofu [style=invis];
    }

    // ==========================================
    // CLUSTER 2: External Resources (Moved to Left Side)
    // ==========================================
    subgraph cluster_external {
        label="External Resources";
        style="rounded,filled"; fillcolor="#2A2A2A"; color="#444444"; fontcolor="#E0E0E0"; 
        fontsize=14; 
        margin=20;
        
        {rank=same; azure_kv; synology_nas;} // Put them side-by-side to match the width of other clusters
        
        node [fillcolor="#005A9E", color="#004578"]; 
        azure_kv [label="Azure Key Vault\nSecrets Backend"];
        
        node [fillcolor="#4A5568", color="#2D3748"]; 
        synology_nas [label="Synology NAS\nNFS Volumes"];
    }

    // ==========================================
    // CLUSTER 3: Network Entry & Routing
    // ==========================================
    subgraph cluster_network {
        label="Network Entry & Routing";
        style="rounded,filled"; fillcolor="#2A2A2A"; color="#444444"; fontcolor="#E0E0E0"; 
        fontsize=14; 
        margin=20; 
        node [fillcolor="#1A365D", color="#2A4365"]; 

        public_users [label="Public Users"];
        lan_users [label="LAN Users"];
        tailnet_users [label="Tailnet Users"];
        
        cloudflare [label="Cloudflare\n(DNS + Zero Trust)"];
        haproxy [label="HAProxy (3 VMs)\nL4 LB + SSL"];
        traefik [label="Traefik\nIngress Controller"];

        public_users -> cloudflare [xlabel=" HTTPS"];
        lan_users -> haproxy [xlabel=" Local LAN"];
        tailnet_users -> haproxy [xlabel=" Tailscale"];
        cloudflare -> traefik [xlabel=" Tunnel"];
        haproxy -> traefik [xlabel=" Internal"];
    }

    // ==========================================
    // CLUSTER 4: Infrastructure & Platform
    // ==========================================
    subgraph cluster_infra {
        label="Infrastructure & Platform";
        style="rounded,filled"; fillcolor="#2A2A2A"; color="#444444"; fontcolor="#E0E0E0"; 
        fontsize=14; 
        margin=20;
        node [fillcolor="#22543D", color="#276749"]; 

        proxmox [label="Proxmox VE\n2 Mini PCs, 1 GPU PC"];
        k3s [label="K3s Kubernetes\nControl Planes + GPU Worker"];
        
        platform_svcs [label="Core Platform\nCert Manager, Harbor, Rancher"];
        data_storage [label="Data & Storage\nCloudNativePG, Synology CSI"];
        observability [label="Observability\nPrometheus, Grafana, Loki, Velero"];
        
        {rank=same; proxmox; k3s;}
        {rank=same; platform_svcs; data_storage; observability;}
        proxmox -> platform_svcs [style=invis]; 
    }

    // ==========================================
    // CLUSTER 5: Production Workloads
    // ==========================================
    subgraph cluster_workloads {
        label="Production Workloads";
        style="rounded,filled"; fillcolor="#2A2A2A"; color="#444444"; fontcolor="#E0E0E0"; 
        fontsize=14; 
        margin=20;
        node [fillcolor="#742A2A", color="#9B2C2C"]; 

        ai_apps [label="AI & LLM Stack\nvLLM, LiteLLM, Open WebUI"];
        media_apps [label="Media & Docs\nJellyfin, *arr, Immich, Paperless"];
        auto_apps [label="Dev & Auto\nn8n, OpenCode, Coder"];
        utility_apps [label="Utility & Home\nHomepage, Home Assistant"];
    }

    // ==========================================
    // SYSTEM RELATIONSHIPS & FLOW
    // ==========================================
    
    // Provisioning & Config Flow
    opentofu -> proxmox [label=" Provisions VMs", style="dashed", color="#A0AEC0"];
    fluxcd -> k3s [label=" Reconciles K8s", style="dashed", color="#A0AEC0"];
    nixos -> k3s [label=" OS Config", style="dashed", color="#A0AEC0"];
    
    // External Integrations (Now flowing left-to-right perfectly)
    azure_kv -> platform_svcs [label=" Secrets Provider", style="dashed", color="#63B3ED", fontcolor="#63B3ED"];
    synology_nas -> data_storage [label=" Mounts PVs", style="dashed", color="#63B3ED", fontcolor="#63B3ED"];

    // Application Traffic Flow
    traefik -> ai_apps [lhead="cluster_workloads", label=" Routes App Traffic", color="#F6AD55", fontcolor="#F6AD55"];
    
    // Structural Anchor (Hidden) - Pulls top and bottom halves together
    k3s -> ai_apps [style=invis];
}
