digraph homelab {
    graph [
        // newrank=true,
        rankdir=TB, 
        compound=true, 
        splines=ortho, 
        pad=0.5,            
        nodesep=0.4,        
        ranksep=1.2,        
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=16,        
        bgcolor="#09090B"
    ];

    // Global Node Defaults 
    node [
        shape=box, 
        style="rounded,filled", 
        fillcolor="#18181B",
        color="#3F3F46",
        fontcolor="#FAFAFA", 
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=11,        
        margin="0.2,0.15",
        penwidth=1.5
    ];
    
    // Global Edge Defaults
    edge [
        color="#52525B", 
        fontcolor="#A1A1AA", 
        fontname="Inter, Helvetica, sans-serif", 
        fontsize=10,        
        penwidth=1.2, 
        arrowsize=0.8
    ];

    subgraph cluster_gitops {
        label="GITOPS & IaC";
        style="rounded,filled"; fillcolor="#111111"; color="#7C3AED"; fontcolor="#A78BFA"; 
        fontsize=13; margin=15; 
        node [color="#7C3AED"]; 

        github [label="GitHub Repo\nFlux + Tofu Sources"];
        nixos  [label="NixOS\nOS Config"];
        tofu   [label="OpenTofu\nVM Provisioning"];
        flux   [label="FluxCD\nK8s Reconciliation"];

        // Enforce horizontal order to prevent crossing lines
        {rank=same; github -> flux -> nixos -> tofu [style=invis]}
    }

    subgraph cluster_network {
        label="NETWORK ENTRY";
        style="rounded,filled"; fillcolor="#111111"; color="#3B82F6"; fontcolor="#93C5FD"; 
        fontsize=13; margin=15;
        node [color="#3B82F6"];

        public      [label="Public"];
        private     [label="Private"];

        {rank=same; public -> private [style=invis]}
    }

    subgraph cluster_external {
        label="EXTERNAL";
        style="rounded,filled"; fillcolor="#111111"; color="#0EA5E9"; fontcolor="#7DD3FC"; 
        fontsize=13; margin=15;
        node [color="#0EA5E9"];
        
        azure_kv [label="Azure Key Vault"];
        cloudflare  [label="Cloudflare\nDNS & Proxy"];

        {rank=same; azure_kv -> cloudflare [style=invis]}
    }

    subgraph cluster_hardware {
        label="HARDWARE";
        style="rounded,filled"; fillcolor="#111111"; color="#10B981"; fontcolor="#6EE7B7"; 
        fontsize=13; margin=15;
        node [color="#10B981"];

        proxmox     [label="Proxmox VE Cluster\n3 Nodes"];
        syn_nas  [label="Synology NAS\nNFS Volumes & LUN"];

        {rank=same; syn_nas -> proxmox [style=invis]}
    }

    subgraph cluster_vm {
      label="VIRTUAL MACHINES";
      style="rounded,filled"; fillcolor="#111111"; color="#EF4444";
      fontcolor="#FCA5A1"; fontsize=13; margin=15;
      node [color="#EF4444"];

      haproxy     [label="HAProxy x3"];
      pihole      [label="Pi-hole & Tailscale"];
      opencode     [label="OpenCode"];

      {rank=same; haproxy -> pihole -> opencode [style=invis]}
    }

    subgraph cluster_infra {
        label="KUBERNETES INFRASTRUCTURE";
        style="rounded,filled"; fillcolor="#111111"; color="#EF4444"; fontcolor="#FCA5A1";
        fontsize=13; margin=15;
        node [color="#EF4444"];

        storage     [label="Data & Storage & Backup\nCloudNativePG, Velero"];
        platform    [label="Core Services\nCert-Manager, Harbor"];
        ingress     [label="Traefik Ingress\nController"];
        obs         [label="Observability\nPrometheus, Grafana, Loki"];

        {rank=same; platform -> ingress -> storage -> obs [style=invis]}
    }

    subgraph cluster_workloads {
        label="PRODUCTION WORKLOADS";
        style="rounded,filled"; fillcolor="#111111"; color="#EF4444"; fontcolor="#FCA5A1"; 
        fontsize=13; margin=15;
        node [color="#EF4444"];

        ai_apps   [label="AI: LiteLLM, Open WebUI", color="#EF4444"];
        media     [label="Media: Jellyfin, *arr", color="#EF4444"];
        docs      [label="Docs: Paperless, Karakeep", color="#EF4444"];
        utility   [label="Util: Homepage, Budget", color="#EF4444"];
        dev       [label="Dev: n8n, Coder", color="#EF4444"];
        home      [label="Home: Assistant, MC", color="#EF4444"];

        {rank=same; ai_apps -> media -> docs -> utility -> dev -> home [style=invis]}
    }

    // ==========================================
    // SYSTEM WIRING (Horizontal "Blueprints")
    // ==========================================
    
    // Provisioning (Added weights to naturally pull GitOps to the right targets)
    tofu -> proxmox       [rhead=cluster_hardware, xlabel=" Provisions ", style=dashed, color="#A1A1AA", weight=10];
    nixos -> opencode     [lhead=cluster_vm, xlabel=" Configures ", style=dashed, color="#A1A1AA", weight=10];
    proxmox -> pihole      [rhead=cluster_vm, xlabel=" Hosts ", style=dashed, color="#A1A1AA"];
    flux -> storage    [lhead=cluster_infra, xlabel=" Reconciles ", style=dashed, color="#A1A1AA", weight=10];
    
    // Data & Secrets
    azure_kv -> platform [xlabel=" Secrets ", style=dashed, color="#0EA5E9"];
    syn_nas -> storage   [lhead=cluster_infra, xlabel=" Mounts ", style=dashed, color="#0EA5E9"];

    // Traffic Flow (Added weight=10 to main flows to enforce straight vertical lines)
    public -> cloudflare [color="#3B82F6", penwidth=2, xlabel=" Routes Traffic ", weight=10];
    cloudflare -> ingress [color="#3B82F6", penwidth=2, xlabel=" Routes Traffic ", weight=10];
    private -> pihole [color="#3B82F6", penwidth=2, xlabel=" Routes Traffic ", weight=5];
    pihole -> haproxy [color="#3B82F6", penwidth=2, xlabel=" Routes Traffic "];
    haproxy -> ingress [color="#3B82F6", penwidth=2, xlabel=" Routes Traffic "];
    ingress -> docs [lhead=cluster_workloads, color="#F59E0B", penwidth=2, xlabel=" Routes Traffic ", weight=10];

    // ==========================================
    // HIDDEN ANCHORS FOR BALANCED ALIGNMENT
    // ==========================================
    // These vertical spines force the centers of the clusters to align beautifully
    edge [style=invis, weight=100];
    
    // Left Spine
    azure_kv -> haproxy -> platform -> ai_apps;
    
    // Center-Left Spine (Main Public Flow)
    public -> cloudflare -> ingress -> docs;
    
    // Center Spine (Main Private Flow)
    private -> pihole -> storage -> utility;
    
    // Center-Right Spine
    syn_nas -> opencode -> obs -> dev;
    
    // Right Spine
    proxmox -> home;
}
