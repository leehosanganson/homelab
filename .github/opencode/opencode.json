{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../../AGENTS.md"],
  "default_agent": "architect",
  "permission": {
    "*": "deny"
  },
  "agent": {
    "architect": {
      "description": "Architects work and delegates implementation to generator",
      "mode": "primary",
      "prompt": "{file:../agents/architect.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "question": "deny",
        "task": {
          "*": "deny",
          "generator": "allow"
        }
      }
    },
    "generator": {
      "description": "Implements architect steps and delegates validation",
      "mode": "subagent",
      "prompt": "{file:../agents/generator.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "question": "deny",
        "external_directory": "deny",
        "bash": {
          "*": "deny",

          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",

          "git checkout -b *": "allow",
          "git switch -c *": "allow",

          "git add *": "allow",
          "git commit -m *": "allow",
          "git push -u origin feat/*": "allow",
          "git push -u origin fix/*": "allow",
          "git push -u origin chore/*": "allow",

          "gh pr create --draft *": "allow",

          "python -c *": "deny",
          "node -e *": "deny",
          "sh -c *": "deny",
          "bash -c *": "deny",

          "rm *": "deny",
          "rmdir *": "deny",
          "truncate *": "deny",

          "curl *": "deny",
          "wget *": "deny",
          "ssh *": "deny",
          "scp *": "deny",
          "sftp *": "deny",
          "rsync *": "deny",
          "nc *": "deny",

          "git reset --hard *": "deny",
          "git clean -fdx *": "deny",
          "git push -f *": "deny",
          "git push --force *": "deny",
          "git push --force-with-lease *": "deny",

          "gh auth *": "deny",
          "gh secret *": "deny",
          "gh variable *": "deny",
          "gh pr edit *": "deny",
          "gh pr merge *": "deny",
          "gh pr close *": "deny",
          "gh issue edit *": "deny",
          "gh issue close *": "deny",
          "gh issue create *": "deny",
          "gh workflow *": "deny",

          "git push * main*": "deny",
          "git push * master*": "deny"
        },
        "task": {
          "*": "deny",
          "evaluator": "allow"
        }
      }
    },
    "evaluator": {
      "description": "Validates generator output against plan and constraints",
      "mode": "subagent",
      "prompt": "{file:../agents/evaluator.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git rev-parse": "allow",
          "git rev-parse *": "allow",

          "gh pr view": "allow",
          "gh pr view *": "allow",
          "gh issue view": "allow",
          "gh issue view *": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://litellm.leehosanganson.dev/v1",
        "apiKey": "{env:LITELLM_KEY}"
      },
      "models": {
        "unsloth/qwen-3.6": {
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  }
}
