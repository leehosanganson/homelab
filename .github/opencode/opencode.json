  "agent": {
    "architect": {
      "description": "Architects work and delegates implementation to generator",
      "mode": "primary",
      "prompt": "{file:../agents/architect.md}",
      "permission": {
        "task": {
          "*": "deny",
          "generator": "allow"
        },
        "todowrite": "allow"
      }
    },
    "generator": {
      "description": "Implements architect steps and delegates validation",
      "mode": "subagent",
      "prompt": "{file:../agents/generator.md}",
      "permission": {
        "task": {
          "*": "deny",
          "evaluator": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "skill": "allow"
      }
    },
    "evaluator": {
      "description": "Validates generator output against plan and constraints",
      "mode": "subagent",
      "prompt": "{file:../agents/evaluator.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
