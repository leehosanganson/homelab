{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../../AGENTS.md"],
  "default_agent": "architect",
  "agent": {
    "architect": {
      "description": "Orchestrates implementation by planning and delegating to generator. Uses explore for codebase context and scout for external docs research.",
      "mode": "primary",
      "prompt": "{file:../agents/architect.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": {
          "generator": "allow",
          "explore": "allow",
          "scout": "allow"
        }
      }
    },
    "generator": {
      "description": "Implements the architect's plan. Uses explore for understanding code context before making changes.",
      "mode": "subagent",
      "prompt": "{file:../agents/generator.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": {
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git checkout -b *": "allow",
          "git switch -c *": "allow",
          "git add *": "allow",
          "git commit -m *": "allow",
          "git push -u origin feat/*": "allow",
          "git push -u origin fix/*": "allow",
          "git push -u origin chore/*": "allow",
          "gh pr create --draft *": "allow"
        },
        "task": {
          "evaluator": "allow",
          "explore": "allow"
        }
      }
    },
    "evaluator": {
      "description": "Validates generator output against plan and constraints. Read-only review.",
      "mode": "subagent",
      "prompt": "{file:../agents/evaluator.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git rev-parse": "allow",
          "git rev-parse *": "allow",
          "gh pr view": "allow",
          "gh pr view *": "allow",
          "gh issue view": "allow",
          "gh issue view *": "allow"
        }
      }
    },
    "renovate-review": {
      "description": "Automatically reviews Renovate dependency update pull requests. Uses explore subagent for codebase scanning and gh CLI for PR comment posting.",
      "mode": "primary",
      "prompt": "{file:../agents/renovate-review.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
          "explore": "allow"
        },
        "bash": {
          "gh pr comment *": "allow",
          "gh api repos/*": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://litellm.leehosanganson.dev/v1",
        "apiKey": "{env:LITELLM_KEY}"
      },
      "models": {
        "unsloth/qwen-3.6": {
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  }
}
