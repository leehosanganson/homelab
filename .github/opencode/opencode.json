{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../../AGENTS.md"],
  "default_agent": "architect",
  "permission": {
    "*": "deny",
    "question": "deny"
  },
  "agent": {
    "architect": {
      "description": "Architects work and delegates implementation to generator",
      "mode": "primary",
      "prompt": "{file:../agents/architect.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
          "*": "deny",
          "generator": "allow"
        },
        "bash": {
          "*": "deny",
          "gh issue comment *": "allow",
          "gh pr comment *": "allow",
          "gh api *": "allow"
        },
        "question": "deny",
        "edit": "deny",
        "external_directory": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "deny",
        "skill": "allow",
        "todowrite": "allow",
        "doom_loop": "deny"
      }
    },
    "generator": {
      "description": "Implements architect steps and delegates validation",
      "mode": "subagent",
      "prompt": "{file:../agents/generator.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
          "*": "deny",
          "evaluator": "allow"
        },
        "bash": {
          "*": "deny",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git rev-parse *": "allow",
          "gh issue comment *": "allow",
          "gh pr comment *": "allow"
        },
        "question": "deny",
        "external_directory": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "deny",
        "skill": "allow",
        "todowrite": "deny",
        "doom_loop": "deny"
      }
    },
    "evaluator": {
      "description": "Validates generator output against plan and constraints",
      "mode": "subagent",
      "prompt": "{file:../agents/evaluator.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "*": "deny",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "gh issue comment *": "allow",
          "gh pr comment *": "allow"
        },
        "task": "deny",
        "question": "deny",
        "edit": "deny",
        "external_directory": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "deny",
        "skill": "allow",
        "todowrite": "deny",
        "doom_loop": "deny"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://litellm.leehosanganson.dev/v1",
        "apiKey": "{env:LITELLM_KEY}"
      },
      "models": {
        "unsloth/qwen-3.6": {
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  }
}
