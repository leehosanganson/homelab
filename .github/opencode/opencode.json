{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../../AGENTS.md"],
  "default_agent": "architect",
  "permission": {
    "*": "deny"
  },
  "agent": {
    "architect": {
      "description": "Architects work and delegates implementation to generator",
      "mode": "primary",
      "prompt": "{file:../agents/architect.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
          "generator": "allow"
        }
      }
    },
    "generator": {
      "description": "Implements architect steps and delegates validation",
      "mode": "subagent",
      "prompt": "{file:../agents/generator.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": {
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",

          "git checkout -b *": "allow",
          "git switch -c *": "allow",

          "git add *": "allow",
          "git commit -m *": "allow",
          "git push -u origin feat/*": "allow",
          "git push -u origin fix/*": "allow",
          "git push -u origin chore/*": "allow",

          "gh pr create --draft *": "allow"
        },
        "task": {
          "evaluator": "allow"
        }
      }
    },
    "evaluator": {
      "description": "Validates generator output against plan and constraints",
      "mode": "subagent",
      "prompt": "{file:../agents/evaluator.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git rev-parse": "allow",
          "git rev-parse *": "allow",

          "gh pr view": "allow",
          "gh pr view *": "allow",
          "gh issue view": "allow",
          "gh issue view *": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://litellm.leehosanganson.dev/v1",
        "apiKey": "{env:LITELLM_KEY}"
      },
      "models": {
        "unsloth/qwen-3.6": {
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  }
}
